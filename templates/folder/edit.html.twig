{% extends 'base.html.twig' %}
{% block title %}Modifier le dossier{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 flex items-center justify-center">

    {{ form_start(form, {attr: {id: 'folder-form'}}) }}

    <div class="bg-white rounded-2xl shadow-lg w-full max-w-md p-6 relative">

        <div class="flex items-start justify-between mb-4">
            <div>
                <h2 class="text-lg font-semibold text-gray-900">Modifier le dossier</h2>
                <p class="text-sm text-gray-400 mt-0.5">Mettez à jour le nom et la couleur du dossier.</p>
            </div>
            <a href="{{ path('app_folder_index') }}" class="text-gray-400 hover:text-gray-600 transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </a>
        </div>

        <div class="mb-4">
            <label class="block text-sm font-medium text-gray-700 mb-1">Nom du dossier</label>
            {{ form_widget(form.name, {attr: {
                class: 'w-full px-4 py-2.5 bg-gray-100 border-0 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300',
                placeholder: 'Ex: Travail'
            }}) }}
            {{ form_errors(form.name) }}
        </div>

        <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Couleur</label>
            {{ form_widget(form.color, {attr: {id: 'color-input', class: 'w-full h-10 rounded-lg border border-gray-200'}}) }}
            <div class="grid grid-cols-8 gap-2" id="color-picker">
                {% set colors = [
                    '#ef4444', '#f97316', '#f59e0b', '#eab308',
                    '#84cc16', '#22c55e', '#10b981', '#14b8a6',
                    '#06b6d4', '#0ea5e9', '#3b82f6', '#6366f1',
                    '#8b5cf6', '#a855f7', '#d946ef', '#ec4899'
                ] %}
                {% for color in colors %}
                    <button type="button"
                            data-color="{{ color }}"
                            class="color-swatch w-9 h-9 rounded-lg transition-all ring-offset-2 hover:scale-110"
                            style="background-color: {{ color }}">
                    </button>
                {% endfor %}
            </div>
        </div>

        <div class="flex justify-end gap-2">
            <a href="{{ path('app_folder_index') }}"
               class="px-4 py-2 text-sm text-gray-700 border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                Annuler
            </a>
            <button type="submit"
                    class="px-5 py-2 text-sm font-medium text-white bg-gray-900 rounded-lg hover:bg-gray-700 transition">
                Enregistrer
            </button>
        </div>

    </div>

    {{ form_end(form) }}

</div>

<script>
function getColorInput() {
    return document.getElementById('color-input') || document.querySelector('input[name$="[color]"]');
}

function selectColor(hex) {
    const input = getColorInput();
    if (!input) {
        return;
    }

    input.value = hex;
    input.dispatchEvent(new Event('input', { bubbles: true }));

    document.querySelectorAll('.color-swatch').forEach(btn => {
        const isSelected = btn.dataset.color === hex;
        btn.classList.toggle('ring-2', isSelected);
        btn.classList.toggle('ring-gray-900', isSelected);
        btn.classList.toggle('scale-110', isSelected);
    });
}

document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.color-swatch').forEach(btn => {
        btn.addEventListener('click', () => selectColor(btn.dataset.color));
    });

    const initialColor = getColorInput()?.value || '#ef4444';
    selectColor(initialColor);
});
</script>
{% endblock %}
