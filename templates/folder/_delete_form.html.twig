<form method="post" action="{{ path('app_folder_delete', {'id': folder.id}) }}" onsubmit="return confirm('Etes vous sûr de vouloir supprimer votre dossier ?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ folder.id) }}">
    <button class="btn">Supprimer</button>
</form>
