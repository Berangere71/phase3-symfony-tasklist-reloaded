{% extends 'base.html.twig' %}

{% block title %}Gestion des dossiers{% endblock %}

{% block body %}
<div class="px-8 py-6">
    <div class="flex items-center justify-between mb-6">
        <div>
            <h1 class="text-2xl font-semibold text-gray-900">Dossiers</h1>
            <p class="text-sm text-gray-500">Liste des dossiers disponibles pour organiser vos tâches.</p>
        </div>
        <div class="flex items-center gap-3">
            <a href="{{ path('dashboard') }}" class="px-6 py-2.5 rounded-lg border border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition-colors">
                Retour au dashboard
            </a>
            <a href="{{ path('app_folder_new') }}" class="inline-flex items-center px-4 py-2 bg-slate-900 text-white text-sm font-medium rounded-lg hover:bg-slate-800 transition">
                Nouveau dossier
            </a>
        </div>
    </div>

    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">ID</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Nom</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Couleur</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 bg-white">
                {% for folder in folders %}
                    <tr>
                        <td class="px-4 py-4 text-sm text-gray-700">{{ folder.id }}</td>
                        <td class="px-4 py-4 text-sm text-gray-700">{{ folder.name }}</td>
                        <td class="px-4 py-4 text-sm text-gray-700">
                            <span class="inline-flex items-center gap-2">
                                <span class="w-4 h-4 rounded-full" style="background-color: {{ folder.color ?: '#000' }}"></span>
                                {{ folder.color ?: 'Aucune' }}
                            </span>
                        </td>
                        <td class="px-4 py-4 text-sm text-gray-700 space-x-2">
                            <a href="{{ path('app_folder_edit', {'id': folder.id}) }}" class="text-slate-900 hover:underline">Modifier</a>
                            <form method="post" action="{{ path('app_folder_delete', {'id': folder.id}) }}" class="inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ folder.id) }}">
                                <button type="submit" class="text-red-600 hover:underline">Supprimer</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="px-4 py-8 text-center text-sm text-gray-500">Aucun dossier trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% block title %}Dossier index{% endblock %}

{% block body %}
    <h1>Dossier index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for folder in folders %}
            <tr>
                <td>{{ folder.id }}</td>
                <td>{{ folder.name }}</td>
                <td>
                    <a href="{{ path('app_folder_show', {'id': folder.id}) }}">Tous</a>
                    <a href="{{ path('app_folder_edit', {'id': folder.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">l'enregistrement non trouvé</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_folder_new') }}">nouveau</a>
{% endblock %}
