{% extends 'base.html.twig' %}
{% block title %}Gérer les priorités{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50 p-6">
    <div class="max-w-2xl mx-auto">

        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-xl font-semibold text-gray-900">Gérer les priorités</h1>
                <p class="text-sm text-gray-400">Définissez les niveaux de priorité de vos tâches</p>
            </div>
            <div class="flex gap-2">
                <a href="{{ path('app_priority_new') }}"
                   class="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white bg-gray-900 rounded-lg hover:bg-gray-700 transition">
                    + Nouvelle priorité
                </a>
                <a href="{{ path('dashboard') }}"
                   class="px-4 py-2 text-sm text-gray-700 border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                    Retour
                </a>
            </div>
        </div>

        {% if priorities is empty %}
            <div class="bg-white rounded-xl border border-gray-200 p-12 text-center">
                <p class="text-gray-400 text-sm">Aucune priorité créée. Créez votre première priorité !</p>
            </div>
        {% else %}
            <div class="space-y-2">
                {% for priority in priorities %}
                    <div class="bg-white border border-gray-200 rounded-xl px-5 py-4 flex items-center justify-between">
                        <div>
                            <span class="text-sm font-medium rounded px-2 py-1 {{ priority.bgColor }} {{ priority.textColor }}">{{ priority.name }}</span>
                            <span class="ml-2 text-xs text-gray-400">importance : {{ priority.importance }}</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <a href="{{ path('app_priority_edit', {id: priority.id}) }}"
                               class="p-1.5 rounded-lg text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                          d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                </svg>
                            </a>
                            <form method="post" action="{{ path('app_priority_delete', {id: priority.id}) }}"
                                  onsubmit="return confirm('Supprimer cette priorité ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ priority.id) }}">
                                <button type="submit"
                                        class="p-1.5 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 transition">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                    </svg>
                                </button>
                            </form>
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% block title %}Priority index{% endblock %}

{% block body %}
    <h1>Priority index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Importance</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for priority in priorities %}
            <tr>
                <td>{{ priority.id }}</td>
                <td>{{ priority.name }}</td>
                <td>{{ priority.importance }}</td>
                <td>
                    <a href="{{ path('app_priority_show', {'id': priority.id}) }}">show</a>
                    <a href="{{ path('app_priority_edit', {'id': priority.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_priority_new') }}">Create new</a>
{% endblock %}
