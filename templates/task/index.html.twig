{% extends 'base.html.twig' %}
{% block title %}Gestion de Tâches{% endblock %}
{% block body %}

<div class="flex min-h-screen bg-gray-50">

  <!-- Sidebar -->
  <aside class="w-52 bg-gray-900 text-white flex flex-col p-4 gap-4">
    
    <!-- Toutes les tâches -->
    <a href="{{ path('app_tasks') }}" class="flex items-center gap-2 bg-gray-700 rounded-lg px-3 py-2 text-sm font-medium">
      🏠 Toutes les tâches
    </a>

    <!-- Dossiers -->
    <div>
      <p class="text-xs text-gray-400 uppercase mb-2">Dossiers</p>
      {% for folder in folders %}
        <div class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-700 cursor-pointer text-sm">
          <span class="w-2 h-2 rounded-full bg-green-400"></span>
          📁 {{ folder.name }}
        </div>
      {% endfor %}
    </div>

  </aside>

  <!-- Contenu principal -->
  <div class="flex-1 flex flex-col">

    <!-- Header -->
    <header class="flex items-center justify-between px-8 py-4 border-b bg-white">
      <div>
        <h1 class="text-xl font-semibold text-gray-900">Gestion de Tâches</h1>
        <p class="text-sm text-gray-400">Organisez votre journée efficacement</p>
      </div>
      <div class="flex items-center gap-3">
        <a href="#" class="flex items-center gap-2 border rounded-lg px-4 py-2 text-sm hover:bg-gray-50">
          ⚙️ Gérer les priorités
        </a>
        <a href="#" class="flex items-center gap-2 border rounded-lg px-4 py-2 text-sm hover:bg-gray-50">
          📁 Nouveau dossier
        </a>
        <a href="{{ path('app_task_new') }}" class="flex items-center gap-2 bg-gray-900 text-white rounded-lg px-4 py-2 text-sm hover:bg-gray-700">
          + Nouvelle tâche
        </a>
        <a href="{{ logout_path() }}" class="flex items-center gap-2 border rounded-lg px-4 py-2 text-sm hover:bg-gray-50">
          ↪ Déconnexion
        </a>
      </div>
    </header>

    <!-- Filtres -->
    <div class="flex items-center gap-4 px-8 py-4">
      <span class="text-sm text-gray-500">🔽 Filtres :</span>
      <form method="get" class="flex items-center gap-4">
        
        <label class="text-sm font-medium text-gray-700">Statut</label>
        <select name="status" onchange="this.form.submit()" class="border rounded-lg px-3 py-1.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-300">
          <option value="">Tous</option>
          {% for status in statuses %}
            <option value="{{ status.value }}" {% if currentStatus == status.value %}selected{% endif %}>
              {{ status.value|capitalize }}
            </option>
          {% endfor %}
        </select>

        <label class="text-sm font-medium text-gray-700">Priorité</label>
        <select name="priority" onchange="this.form.submit()" class="border rounded-lg px-3 py-1.5 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-300">
          <option value="">Toutes</option>
          {% for priority in priorities %}
            <option value="{{ priority.value }}" {% if currentPriority == priority.value %}selected{% endif %}>
              {{ priority.value|capitalize }}
            </option>
          {% endfor %}
        </select>

      </form>
    </div>

    <!-- Liste des tâches -->
    <main class="px-8 py-4 flex flex-col gap-3">
      {% for task in tasks %}
        <div class="flex items-center justify-between bg-white border rounded-xl px-5 py-4 hover:shadow-sm transition">
          
          <div class="flex items-center gap-4">
            <!-- Checkbox -->
            <input type="checkbox" class="w-4 h-4 accent-gray-900 cursor-pointer" {% if task.status.value == 'terminé' %}checked{% endif %}>
            
            <div>
              <!-- Titre + badge priorité -->
              <div class="flex items-center gap-2">
                <span class="text-sm font-medium text-gray-900">{{ task.title }}</span>
                {% if task.priority %}
                  <span class="text-xs px-2 py-0.5 rounded-full font-medium
                    {% if task.priority.value == 'urgent' %} bg-red-100 text-red-500
                    {% elseif task.priority.value == 'important' %} bg-orange-100 text-orange-500
                    {% else %} bg-blue-100 text-blue-500
                    {% endif %}">
                    {{ task.priority.value }}
                  </span>
                {% endif %}
              </div>
              <!-- Statut -->
              <p class="text-xs text-gray-400 mt-0.5">{{ task.status.value|capitalize }}</p>
            </div>
          </div>

          <!-- Pin -->
          <form method="post" action="{{ path('app_task_pin', {id: task.id}) }}">
            <button type="submit" class="text-gray-300 hover:text-gray-600 transition">
              {% if task.isPinned %}📌{% else %}📍{% endif %}
            </button>
          </form>

        </div>
      {% else %}
        <p class="text-sm text-gray-400 text-center mt-10">Aucune tâche trouvée.</p>
      {% endfor %}
    </main>

  </div>
</div>

{% endblock %}