{% extends 'base.html.twig' %}
{% block title %}Nouvelle tâche{% endblock %}
{% block body %}

<div class="min-h-screen bg-gray-50 flex items-center justify-center">
  <div class="bg-white rounded-2xl shadow-md p-8 w-full max-w-sm">

    <h1 class="text-xl font-semibold text-gray-900 mb-1">Nouvelle tâche</h1>
    <p class="text-sm text-gray-400 mb-6">Ajoutez une tâche à votre liste</p>

    <form method="post" class="space-y-4">

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Titre</label>
        <input type="text" name="title" required
          class="w-full px-4 py-2.5 bg-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300"
          placeholder="Nom de la tâche">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Priorité</label>
        <select name="priority"
          class="w-full px-4 py-2.5 bg-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300">
          <option value="">Aucune</option>
          {% for priority in priorities %}
            <option value="{{ priority.value }}">{{ priority.value|capitalize }}</option>
          {% endfor %}
        </select>
      </div>

      <button type="submit"
        class="w-full bg-gray-900 text-white py-3 rounded-lg text-sm font-medium hover:bg-gray-700 transition-colors">
        Créer la tâche
      </button>

      <a href="{{ path('app_tasks') }}"
        class="block text-center text-sm text-gray-400 hover:text-gray-600 mt-2">
        Annuler
      </a>

    </form>
  </div>
</div>

{% endblock %}