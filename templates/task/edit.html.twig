{% extends 'base.html.twig' %}

{% block title %}Modifier la tâche{% endblock %}

{% block body %}
    <div class="fixed inset-0 bg-gray-600 bg-opacity-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden relative p-8">

            <button class="absolute top-4 right-4 text-gray-400 hover:text-gray-600" type="button" onclick="history.back()">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <header class="mb-6">
                <h2 class="text-xl font-bold text-gray-900">Modifier la tâche</h2>
                <p class="text-sm text-gray-500">Mettez à jour les informations de votre tâche</p>
            </header>

            {{ form_start(form, {'attr': {'class': 'space-y-5'}}) }}

                <div>
                    {{ form_label(form.title, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.title, {'attr': {'class': 'w-full px-4 py-3 bg-gray-100 border-transparent rounded-lg focus:ring-0 focus:bg-white focus:border-gray-300 transition-colors placeholder-gray-400'}}) }}
                </div>

                <div>
                    {{ form_label(form.priority, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.priority, {'attr': {'class': 'w-full px-4 py-3 bg-gray-100 border-transparent rounded-lg focus:ring-0 focus:bg-white focus:border-gray-300 appearance-none'}}) }}
                </div>

                <div>
                    {{ form_label(form.folder, null, {'label_attr': {'class': 'block text-sm font-medium text-gray-700 mb-1'}}) }}
                    {{ form_widget(form.folder, {'attr': {'class': 'w-full px-4 py-3 bg-gray-100 border-transparent rounded-lg focus:ring-0 focus:bg-white focus:border-gray-300 appearance-none'}}) }}
                </div>

                <div class="flex justify-end space-x-3 mt-8">
                    <button type="button" onclick="history.back()" class="px-6 py-2.5 rounded-lg border border-gray-300 text-gray-700 font-medium hover:bg-gray-50 transition-colors">
                        Annuler
                    </button>
                    <button type="submit" class="px-6 py-2.5 rounded-lg bg-black text-white font-medium hover:bg-gray-800 transition-colors">
                        Enregistrer
                    </button>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
