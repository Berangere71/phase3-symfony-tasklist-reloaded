{% extends 'base.html.twig' %}
{% block title %}Inscription{% endblock %}
{% block body %}

<div class="min-h-screen bg-blue-50 flex items-center justify-center">
  <div class="bg-white rounded-2xl shadow-md p-8 w-full max-w-sm">

    <!-- Titre -->
    <h1 class="text-xl font-semibold text-gray-900 mb-1">Gestion de Tâches</h1>
    <p class="text-sm text-gray-400 mb-5">Organisez votre journée efficacement</p>

    <!-- Onglets Connexion / Inscription -->
    <div class="flex bg-gray-100 rounded-full p-1 mb-6">
      <a href="{{ path('app_login') }}" class="flex-1 py-1.5 rounded-full text-sm font-medium text-center text-gray-400 hover:text-gray-600">
        Connexion
      </a>
      <button class="flex-1 py-1.5 rounded-full bg-white text-sm font-medium shadow text-gray-900 text-center">
        Inscription
      </button>
    </div>

    <!-- Erreurs globales -->
    {% if registrationForm.vars.errors|length > 0 %}
      <div class="bg-red-50 text-red-500 text-sm rounded-lg p-3 mb-4">
        {{ form_errors(registrationForm) }}
      </div>
    {% endif %}

    <!-- Formulaire -->
    {{ form_start(registrationForm, {'attr': {'class': 'space-y-4'}}) }}

      <!-- Email -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
        {{ form_widget(registrationForm.email, {
          'attr': {
            'class': 'w-full px-4 py-2.5 bg-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300',
            'placeholder': 'votre@email.com'
          }
        }) }}
        {{ form_errors(registrationForm.email) }}
      </div>

      <!-- Nom d'utilisateur -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Nom d'utilisateur</label>
        {{ form_widget(registrationForm.username, {
          'attr': {
            'class': 'w-full px-4 py-2.5 bg-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300',
            'placeholder': 'nom_utilisateur'
          }
        }) }}
        {{ form_errors(registrationForm.username) }}
      </div>

      <!-- Mot de passe -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Mot de passe</label>
        {{ form_widget(registrationForm.plainPassword, {
          'attr': {
            'class': 'w-full px-4 py-2.5 bg-gray-100 rounded-lg text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-blue-300',
            'placeholder': '••••••••'
          }
        }) }}
        {{ form_errors(registrationForm.plainPassword) }}
      </div>

      <!-- Bouton -->
      <button
        type="submit"
        class="w-full bg-gray-900 text-white py-3 rounded-lg text-sm font-medium hover:bg-gray-700 transition-colors mt-2"
      >
        S'inscrire
      </button>

    {{ form_end(registrationForm) }}

  </div>
</div>

{% endblock %}
