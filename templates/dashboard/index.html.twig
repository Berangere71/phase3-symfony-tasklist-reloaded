{% extends 'base.html.twig' %}

{% block title %}Dashboard - Gestion de Tâches{% endblock %}

{% block body %}
<div class="flex min-h-screen">

    {# ── Sidebar ── #}
    <aside class="w-52 bg-white border-r border-gray-200 flex flex-col shrink-0">
        <div class="p-3">
            <a href="{{ path('dashboard') }}"
               class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm font-medium
                      {{ app.request.attributes.get('_route') == 'dashboard' and not folderId
                         ? 'bg-gray-900 text-white'
                         : 'text-gray-700 hover:bg-gray-100' }}">
                <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
                </svg>
                Toutes les tâches
            </a>
        </div>

        <div class="px-4 pt-2 pb-1">
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider">Dossiers</p>
        </div>

        <nav class="flex-1 px-3 pb-4 overflow-y-auto">
            {% if folders is empty %}
                <p class="text-xs text-gray-400 px-3 py-2">Aucun dossier créé</p>
            {% else %}
                {% for folder in folders %}
                    <a href="{{ path('dashboard', {folder: folder.id}) }}"
                       class="flex items-center gap-2 px-3 py-2 rounded-lg text-sm
                              {{ folderId == folder.id
                                 ? 'bg-gray-100 text-gray-900 font-medium'
                                 : 'text-gray-600 hover:bg-gray-100' }}">
                        <svg class="w-4 h-4 shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                  d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
                        </svg>
                        {{ folder.name }}
                    </a>
                {% endfor %}
            {% endif %}
        </nav>
    </aside>

    {# ── Main content ── #}
    <div class="flex-1 flex flex-col overflow-hidden">

        {# Top navbar #}
        <header class="bg-white border-b border-gray-200 px-6 py-3 flex items-center justify-between shrink-0">
            <div>
                <h1 class="text-xl font-semibold text-gray-900">Gestion de Tâches</h1>
                <p class="text-sm text-gray-400">Organisez votre journée efficacement</p>
            </div>

            <div class="flex items-center gap-2">
                <a href="{{ path('app_priority_index') }}"
                   class="flex items-center gap-1.5 px-3 py-2 text-sm text-gray-700
                          border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    Gérer les priorités
                </a>

                <a href="{{ path('app_folder_new') }}"
                   class="flex items-center gap-1.5 px-3 py-2 text-sm text-gray-700
                          border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 7a2 2 0 012-2h4l2 2h8a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V7z"/>
                    </svg>
                    Nouveau dossier
                </a>

                <a href="{{ path('app_task_new') }}"
                   class="flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-white
                          bg-gray-900 rounded-lg hover:bg-gray-700 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                    </svg>
                    Nouvelle tâche
                </a>

                <a href="{{ path('app_logout') }}"
                   class="flex items-center gap-1.5 px-3 py-2 text-sm text-gray-700
                          border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                    </svg>
                    Déconnexion
                </a>
            </div>
        </header>

        {# Filter bar #}
        <div class="bg-white border-b border-gray-200 px-6 py-3 flex items-center gap-4 shrink-0">
            <div class="flex items-center gap-2 text-sm text-gray-500">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
                </svg>
                Filtres :
            </div>

            <form method="get" id="filter-form" class="flex items-center gap-4">
                <input type="hidden" name="folder" value="{{ folderId ?? '' }}">

                <div class="flex items-center gap-2">
                    <label class="text-sm text-gray-600 font-medium">Statut</label>
                    <select name="status" onchange="this.form.submit()"
                            class="text-sm border border-gray-200 rounded-lg px-3 py-1.5
                                   bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300 cursor-pointer">
                        <option value="" {{ filterStatus is null or filterStatus == '' ? 'selected' }}>Tous</option>
                        <option value="en attente"  {{ filterStatus == 'en attente'  ? 'selected' }}>À faire</option>
                        <option value="en cours"   {{ filterStatus == 'en cours'   ? 'selected' }}>En cours</option>
                        <option value="terminé"    {{ filterStatus == 'terminé'    ? 'selected' }}>Terminé</option>
                    </select>
                </div>

                <div class="flex items-center gap-2">
                    <label class="text-sm text-gray-600 font-medium">Priorité</label>
                    <select name="priority" onchange="this.form.submit()"
                            class="text-sm border border-gray-200 rounded-lg px-3 py-1.5
                                   bg-white text-gray-700 focus:outline-none focus:ring-2 focus:ring-gray-300 cursor-pointer">
                        <option value="" {{ filterPriority is null or filterPriority == '' ? 'selected' }}>Toutes</option>
                        {% for priority in priorities %}
                            <option value="{{ priority.id }}" {{ filterPriority == priority.id ? 'selected' }}>
                                {{ priority.name }}
                            </option>
                        {% endfor %}
                    </select>
                </div>
            </form>
        </div>

        {# Task list #}
        <main class="flex-1 overflow-y-auto p-6">
            {% if tasks is empty %}
                <div class="flex items-center justify-center h-64">
                    <p class="text-gray-400 text-sm">
                        Aucune tâche pour le moment. Créez votre première tâche !
                    </p>
                </div>
            {% else %}
                <div class="space-y-2">
                    {% for task in tasks %}
                        <div class="bg-white border border-gray-200 rounded-xl px-5 py-4
                                    flex items-center justify-between hover:shadow-sm transition group">
                            <div class="flex items-center gap-3">
                                {% if task.isPinned %}
                                    <svg class="w-4 h-4 text-amber-400 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                                    </svg>
                                {% endif %}

                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                                    {{ task.status.value == 'terminé'    ? 'bg-green-100 text-green-700' :
                                       task.status.value == 'en cours'   ? 'bg-blue-100 text-blue-700' :
                                                                           'bg-gray-100 text-gray-600' }}">
                                    {{ task.status.value == 'terminé'    ? 'Terminé' :
                                       task.status.value == 'en cours'   ? 'En cours' : 'À faire' }}
                                </span>

                                <span class="text-sm font-medium text-gray-800
                                             {{ task.status == 'done' ? 'line-through text-gray-400' }}">
                                    {{ task.title }}
                                </span>

                                {% if task.priority is defined and task.priority %}
                                    <span class="text-xs text-gray-400 border border-gray-200 rounded px-2 py-0.5">
                                        {{ task.priority.name }}
                                    </span>
                                {% endif %}
                            </div>

                            <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition">
                                <a href="{{ path('app_task_edit', {id: task.id}) }}"
                                   class="p-1.5 rounded-lg text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                                    </svg>
                                </a>
                                <form method="post" action="{{ path('app_task_delete', {id: task.id}) }}"
                                      onsubmit="return confirm('Supprimer cette tâche ?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.id) }}">
                                    <button type="submit"
                                            class="p-1.5 rounded-lg text-gray-400 hover:text-red-500 hover:bg-red-50 transition">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </main>
    </div>
</div>
{% endblock %}


